# In production the client and API share one Render service.
# Do NOT set NEXT_PUBLIC_API_URL here — leaving it undefined means:
#   - Browser-side: api.ts returns "" (relative paths via Next.js rewrites)
#   - SSR/build: api.ts / api-server.ts fall back to http://localhost:4004
NEXT_PUBLIC_SITE_URL=https://project-cf-coral.onrender.com
